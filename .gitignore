# ==========================================
# 1WELLNESS GITIGNORE
# ==========================================

# Environment files - NEVER COMMIT REAL VALUES
.env
.env.local
.env.development
.env.production
.env.test

# Allow the template file
!.env.example

# Database files
*.db
*.sqlite
*.sqlite3
backend/database/*.db
backend/database/data/*.json

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs
lib-cov

# Coverage directory
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn
.yarn-integrity
.pnp.*

# dotenv environment variables file
.env.test

# PHP
composer.lock
/vendor/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build outputs
dist/
build/
*.min.js
*.min.css

# Temporary files
tmp/
temp/

# Uploads
uploads/
uploads/

# Cache
cache/
.cache/

# System files
.DS_Store
Thumbs.db
desktop.ini

# Backup files
*.bak
*.backup
*.old

# Sensitive certificates and keys
*.pem
*.key
*.crt
*.p12
*.pfx

# DKIM private key — MUST NOT be committed
backend/config/dkim/private.key
backend/config/dkim/*.key

# Cron logs
backend/logs/

# Database dumps
*.sql
!backend/database/schema.sql
!backend/database/*.sql
!backend/database/migrations/*.sql

# Admin database
backend/database/data/admin_users.json
backend/database/data/admin_logs.json

# Webhook queue data
backend/database/data/webhook_queue.json

# User data (privacy)
backend/database/data/users.json
backend/database/data/assessments.json

# Other sensitive data
backend/database/settings.json
backend/debug_log.txt
backend/database/settings.json
backend/database/settings.json
backend/debug_log.txt
*.php~
*- Copy.php
