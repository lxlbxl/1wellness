# ==========================================
# 1WELLNESS ENVIRONMENT CONFIGURATION TEMPLATE
# ==========================================
# Copy this file to .env and fill in your real values
# cp .env.example .env

# ------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=1wellness
DB_USER=root
DB_PASSWORD=your_database_password_here

# SQLite path (if using SQLite)
SQLITE_PATH=./backend/database/ojg_herbal_usd.db

# ------------------------------------------
# ADMIN CONFIGURATION
# ------------------------------------------
ADMIN_EMAIL=admin@ojgherbal.com
ADMIN_PASSWORD=change_this_secure_password

# ------------------------------------------
# SMTP EMAIL CONFIGURATION
# ------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=noreply@ojgherbal.com
SMTP_FROM_NAME=1Wellness

# ------------------------------------------
# FLUTTERWAVE PAYMENT CONFIGURATION
# ------------------------------------------
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_HASH=your_secret_hash_here

# ------------------------------------------
# AI/ORCHESTRATOR CONFIGURATION
# ------------------------------------------
AI_PROVIDER=openrouter
AI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=anthropic/claude-3-5-sonnet

# ------------------------------------------
# WEBHOOK CONFIGURATION
# ------------------------------------------
WEBHOOK_SECRET=your_webhook_secret_here
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

# ------------------------------------------
# APP CONFIGURATION
# ------------------------------------------
APP_NAME=1Wellness
APP_URL=https://1wellness.com
APP_ENV=production

# ------------------------------------------
# SECURITY
# ------------------------------------------
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_32_chars_here

# ------------------------------------------
# MEMBER AREA CONFIGURATION
# ------------------------------------------
MEMBER_API_KEY=your_member_api_key_here